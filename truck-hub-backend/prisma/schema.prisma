generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SHIPPER
  DRIVER
  SUPER_ADMIN
}

enum BookingStatus {
  PENDING
  ACCEPTED
  PICKED_UP
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

enum EscrowStatus {
  HELD
  RELEASED
  DISPUTED
  REFUNDED
}

enum DriverTier {
  BRONZE
  SILVER
  GOLD
  ELITE
}

enum GoodsType {
  ELECTRONICS
  FURNITURE
  AGRICULTURE
  HAZARDOUS
  TEXTILES
  GENERAL_CARGO
}

model User {
  id                String        @id @default(uuid())
  phone             String        @unique
  password          String
  name              String
  email             String        @unique
  role              Role
  rating            Float         @default(5.0)
  verified          Boolean       @default(false)
  goodsCapabilities String[]      @default([])
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  
  // Gamification & Tiers
  driverTier     DriverTier @default(BRONZE)
  loyaltyPoints  Int        @default(0)
  badges         String[]   @default([])
  
  // Digital Business Card Identity
  profileSlug    String?    @unique
  bio            String?

  // Relations
  shipments         Booking[]     @relation("ShipperBookings")
  trips             Booking[]     @relation("DriverTrips")
  vehicles          Vehicle[]
  documents         DriverDocument?
  wallet         Wallet?
  
  // Relations for Preferred Drivers
  preferredDrivers PreferredDriver[] @relation("ShipperPreferences")
  favoritedBy      PreferredDriver[] @relation("FavoritedBy")
}

model PreferredDriver {
  id        Int      @id @default(autoincrement())
  shipperId String   
  driverId  String   
  createdAt DateTime @default(now())

  shipper   User     @relation("ShipperPreferences", fields: [shipperId], references: [id])
  driver    User     @relation("FavoritedBy", fields: [driverId], references: [id])

  // A shipper can only favorite a specific driver once
  @@unique([shipperId, driverId]) 
}

model Wallet {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance       Decimal  @db.Decimal(10, 2) @default(0.00)
  currency      String   @default("USD")
  
  payoutMethod  String?
  payoutAccount String?
  
  updatedAt     DateTime @updatedAt
}

model Vehicle {
  id         String    @id @default(uuid())
  driverId   String
  driver     User      @relation(fields: [driverId], references: [id], onDelete: Cascade)
  type       String    
  plate      String    @unique
  capacity   String 
  status     String    @default("ACTIVE") 
  createdAt  DateTime  @default(now())
  bookings   Booking[]
  maintenanceRecords VehicleMaintenance[]
}

model VehicleMaintenance {
  id            String    @id @default(uuid())
  vehicleId     String
  vehicle       Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  serviceType   String
  cost          Decimal   @db.Decimal(10, 2)
  currency      String    @default("USD")
  serviceDate   DateTime  @default(now())
  nextServiceAt DateTime?
  receiptUrl    String?
  notes         String?
}

model Booking {
  id          Int           @id @default(autoincrement())
  shipperId   String
  shipper     User          @relation("ShipperBookings", fields: [shipperId], references: [id])
  driverId    String?
  driver      User?         @relation("DriverTrips", fields: [driverId], references: [id])
  vehicleId   String?
  vehicle     Vehicle?      @relation(fields: [vehicleId], references: [id])
  
  origin      String
  destination String
  cargo       String
  weight      String
  price       String
  goodsType   GoodsType     @default(GENERAL_CARGO)
  isFragile   Boolean       @default(false)
  status      BookingStatus @default(PENDING)
  progress    Int           @default(0)
  eta         String        @default("TBD")
  date        String        
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  escrow      EscrowTransaction? 

  // Records Vault Fields
  proofOfPickupUrl   String?   
  proofOfDeliveryUrl String?   
  receiptUrl         String?   
  
  // Smart Repeat Booking helper
  isRecurring        Boolean   @default(false)
  recurringFrequency String?   // e.g., "WEEKLY", "MONTHLY"
  
  // Post-trip driver rating
  driverRating       Int?      
  ratingFeedback     String?
}

model EscrowTransaction {
  id          String       @id @default(uuid())
  bookingId   Int          @unique
  booking     Booking      @relation(fields: [bookingId], references: [id])
  amount      Decimal      @db.Decimal(10, 2)
  status      EscrowStatus @default(HELD)
  heldAt      DateTime     @default(now())
  releasedAt  DateTime?
}

model SystemConfiguration {
  id                 String   @id @default("GLOBAL_CONFIG")
  platformFeePercent Float    @default(10.0)
  basePricePerKm     Decimal  @db.Decimal(10, 2) @default(2.50)
  updatedAt          DateTime @updatedAt
}

model AuditTrail {
  id          String   @id @default(uuid())
  adminId     String
  action      String   
  targetId    String   
  details     String
  timestamp   DateTime @default(now())
}
model Notification {
  id         String   @id @default(uuid())
  userId     String   // The recipient of the notification (Driver or Shipper)
  bookingId  Int?     // Optional relation link for direct load claiming actions
  title      String
  message    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model DriverDocument {
  id               String   @id @default(uuid())
  driverId         String   @unique
  driver           User     @relation(fields: [driverId], references: [id], onDelete: Cascade)
  
  // Progressive Step Control
  currentStep      Int      @default(1)
  idNumberTyped    String   @default("")
  idCardPhotoUrl   String   @default("")
  ocrMatched       Boolean  @default(false)
  ocrConfidence    Float    @default(0.0)
  
  // Vetting Metadata & Credentials
  licenseNumber    String   @default("")
  truckPlate       String   @default("")
  insuranceExpiry  DateTime @default("2026-12-31T23:59:59.999Z")
  insuranceFileUrl String   @default("")
  
  // Biometric Facial Rekognition Fields
  selfiePhotoUrl   String   @default("")
  faceMatchScore   Float    @default(0.0)
  faceMatchPassed  Boolean  @default(false)
  
  // Payout Ledger Escrow Verifications
  mpesaValidated   Boolean  @default(false)
  mpesaCheckoutId  String   @default("")
  
  // Resilient Node State Parameters for Single Re-uploads
  idCardStatus     String   @default("PENDING") // PENDING, APPROVED, REJECTED
  licenseStatus    String   @default("PENDING")
  insuranceStatus  String   @default("PENDING")
  selfieStatus     String   @default("PENDING")
  
  status           String   @default("PENDING_REVIEW") // PENDING_REVIEW, APPROVED, REJECTED
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}