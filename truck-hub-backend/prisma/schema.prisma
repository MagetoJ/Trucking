generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // CRITICAL FIX: The "url" parameter has been removed from here to satisfy Prisma 7 rules
}

enum Role {
  SHIPPER
  DRIVER
  SUPER_ADMIN
}

enum BookingStatus {
  PENDING
  ACCEPTED
  PICKED_UP
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

enum EscrowStatus {
  HELD
  RELEASED
  DISPUTED
  REFUNDED
}

model User {
  id                String        @id @default(uuid())
  phone             String        @unique
  password          String
  name              String
  email             String        @unique
  role              Role
  rating            Float         @default(5.0)
  verified          Boolean       @default(false)
  goodsCapabilities String[]      @default([])
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  
  // Relations
  shipments         Booking[]     @relation("ShipperBookings")
  trips             Booking[]     @relation("DriverTrips")
  vehicles          Vehicle[]
}

model Vehicle {
  id         String    @id @default(uuid())
  driverId   String
  driver     User      @relation(fields: [driverId], references: [id], onDelete: Cascade)
  type       String    
  plate      String    @unique
  capacity   String 
  status     String    @default("ACTIVE") 
  createdAt  DateTime  @default(now())
  bookings   Booking[]
}

model Booking {
  id          Int           @id @default(autoincrement())
  shipperId   String
  shipper     User          @relation("ShipperBookings", fields: [shipperId], references: [id])
  driverId    String?
  driver      User?         @relation("DriverTrips", fields: [driverId], references: [id])
  vehicleId   String?
  vehicle     Vehicle?      @relation(fields: [vehicleId], references: [id])
  
  origin      String
  destination String
  cargo       String
  weight      String
  price       String        
  status      BookingStatus @default(PENDING)
  progress    Int           @default(0)
  eta         String        @default("TBD")
  date        String        
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  escrow      EscrowTransaction? 
}

model EscrowTransaction {
  id          String       @id @default(uuid())
  bookingId   Int          @unique
  booking     Booking      @relation(fields: [bookingId], references: [id])
  amount      Decimal      @db.Decimal(10, 2)
  status      EscrowStatus @default(HELD)
  heldAt      DateTime     @default(now())
  releasedAt  DateTime?
}

model SystemConfiguration {
  id                 String   @id @default("GLOBAL_CONFIG")
  platformFeePercent Float    @default(10.0)
  basePricePerKm     Decimal  @db.Decimal(10, 2) @default(2.50)
  updatedAt          DateTime @updatedAt
}

model AuditTrail {
  id          String   @id @default(uuid())
  adminId     String
  action      String   
  targetId    String   
  details     String
  timestamp   DateTime @default(now())
}
model Notification {
  id         String   @id @default(uuid())
  userId     String   // The recipient of the notification (Driver or Shipper)
  title      String
  message    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
}